---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Page not found | Toowoomba Roof Repairs"
  description="The page you were looking for couldn't be found. Get a free Toowoomba roof quote today."
  canonical="https://toowoombaroofrepairs.com.au/404/">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>

  <section class="hero">
    <div class="hero-inner" style="text-align:center;">
      <span class="hero-eyebrow">404</span>
      <h1 style="margin-left:auto; margin-right:auto;">Couldn&rsquo;t find that page.</h1>
      <p class="hero-sub" style="margin-left:auto; margin-right:auto;">
        Try the home page or give us a call &mdash; we&rsquo;ll point you in the right direction.
      </p>
      <div class="hero-actions" style="justify-content:center;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="ph-cta btn btn-ghost" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span> <span class="ph-text">Tap to call</span></a>
      </div>
    </div>
  </section>
</Layout>
