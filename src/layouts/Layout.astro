---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
}

const SITE = 'https://toowoombaroofrepairs.com.au';
const PHONE_DISPLAY = '';
const PHONE_TEL = '+61485939966';
const EMAIL = 'quotes@toowoombaroofrepairs.com.au';
const BIZ_NAME = 'Toowoomba Roof Repairs';

const { title, description, canonical = SITE + '/', ogType = 'website' } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "priceRange": "$$",
  "description": "Roof repair, reroofing and storm & hail damage specialists for Toowoomba and the Darling Downs. Leak repair, cracked-tile and ridge-cap replacement, full tile-to-Colorbond reroofs, metal roofing, roof restoration and insurance hail-claim repairs. QBCC-licensed. Work to AS 1562.1 metal roofing and AS 1170.2 wind actions. Toowoomba sits in the Darling Downs hail belt — we know what spring and summer supercells do to a roof.",
  "areaServed": [
    { "@type": "City", "name": "Toowoomba", "containedInPlace": { "@type": "AdministrativeArea", "name": "Toowoomba Region" } },
    { "@type": "City", "name": "Rangeville" },
    { "@type": "City", "name": "Centenary Heights" },
    { "@type": "City", "name": "Highfields" },
    { "@type": "City", "name": "Wilsonton" },
    { "@type": "City", "name": "Glenvale" },
    { "@type": "City", "name": "Kearneys Spring" },
    { "@type": "City", "name": "Middle Ridge" },
    { "@type": "City", "name": "Darling Heights" },
    { "@type": "City", "name": "Westbrook" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Toowoomba",
    "addressRegion": "QLD",
    "postalCode": "4350",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -27.5598,
    "longitude": 151.9507
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "17:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Roofing Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Repairs (leaks, cracked tiles, ridge capping, flashings)" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Replacement & Reroofing (tile-to-Colorbond, metal reroof)" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Storm & Hail Damage (make-safe + insurance claim repair)" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Metal Roofing & Colorbond (AS 1562.1)" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Restoration & Repointing" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
// BreadcrumbList JSON-LD auto-generated from Astro.url.pathname
const pathname = Astro.url.pathname;
const breadcrumbSegments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" }];
let cumulative = SITE;
breadcrumbSegments.forEach((seg, i) => {
  cumulative += '/' + seg;
  // Human-friendly name: kebab → Title Case, special-case 'services' → Services
  const friendly = seg === 'services'
    ? 'Services'
    : seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": friendly,
    "item": cumulative + '/'
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#1e3a5f">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:secure_url" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={SITE + "/images/og-image.jpg"}>
  <meta name="twitter:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;800&family=Playfair+Display:wght@900&family=Stardos+Stencil:wght@700&display=swap">

  <!-- Google Search Console verification (DNS TXT primary; meta backup) -->
  <meta name="google-site-verification" content="GSC-TOKEN-PLACEHOLDER">

  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://www.google-analytics.com">

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX', {
      'send_page_view': true,
      'anonymize_ip': true
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <slot name="head" />
</head>
<body>
  <div class="top-bar">
    <span>Roof repairs &middot; Reroofing &middot; Storm &amp; hail damage &middot; Servicing Toowoomba &amp; the Darling Downs &middot; <a class="ph-cta" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span></a></span>
  </div>

  <header class="site-header">
    <div class="nav-wrap">
      <a class="brand" href="/" aria-label="Toowoomba Roof Repairs home">
        <img src="/images/logo.svg" alt="Toowoomba Roof Repairs" width="320" height="80" decoding="async">
      </a>
      <ul class="nav-links">
        <li><a href="/services/roof-repairs/">Repairs</a></li>
        <li><a href="/services/roof-replacement/">Replacement</a></li>
        <li><a href="/services/storm-hail-damage/">Storm &amp; Hail</a></li>
        <li><a href="/services/metal-roofing/">Metal</a></li>
        <li><a href="/services/roof-restoration/">Restoration</a></li>
        <li><a href="/toowoomba-region/">Areas</a></li>
      </ul>
      <a class="nav-cta" href="/quote/">Free Quote</a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <h4>Toowoomba Roof Repairs</h4>
        <p style="margin-bottom: 0.75rem;">QBCC-licensed roof repair, reroofing and storm &amp; hail damage specialists for Toowoomba and the Darling Downs. Leak repairs, cracked-tile and ridge-cap replacement, tile-to-Colorbond reroofs, metal roofing and roof restoration. Work to AS 1562.1 and AS 1170.2. Insurance hail-claim repairs welcome.</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Phone:</strong> <a class="ph-cta" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span></a></p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Hours:</strong> Mon&ndash;Sat 7am&ndash;5pm AEST</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Service area:</strong> Toowoomba Region &mdash; city, range suburbs &amp; the Darling Downs</p>
        <p style="margin-bottom: 0;"><strong style="color:#fff;">ABN:</strong> 91 664 546 061</p>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="/services/roof-repairs/">Roof repairs</a></li>
          <li><a href="/services/roof-replacement/">Roof replacement &amp; reroofing</a></li>
          <li><a href="/services/storm-hail-damage/">Storm &amp; hail damage</a></li>
          <li><a href="/services/metal-roofing/">Metal roofing &amp; Colorbond</a></li>
          <li><a href="/services/roof-restoration/">Roof restoration</a></li>
        </ul>
      </div>
      <div>
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/rangeville/">Rangeville</a></li>
          <li><a href="/centenary-heights/">Centenary Heights</a></li>
          <li><a href="/highfields/">Highfields</a></li>
          <li><a href="/wilsonton/">Wilsonton</a></li>
          <li><a href="/glenvale/">Glenvale</a></li>
          <li><a href="/toowoomba-region/">All Toowoomba Region</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-bottom">
      &copy; {new Date().getFullYear()} {BIZ_NAME} &middot; Yes Right Pty Ltd ABN 91 664 546 061. Roof repair, reroofing &amp; storm &amp; hail damage services across Toowoomba &amp; the Darling Downs.
    </p>
  </footer>

  <a class="mobile-phone ph-cta" href="/quote/" aria-label="Call us">
    <span aria-hidden="true">&#9742;</span><span class="ph-text">&nbsp;Tap to call</span>
  </a>
  <script is:inline>
    (function(){
      // 2026-05-23: phone assembled from non-contiguous fragments
      // so no contiguous phone-number substring exists in static HTML.
      // Google can index attributes & visible text; the .ph-cta links default to /quote/
      // for no-JS users, and JS rewrites href to tel: + injects display text.
      var p1 = 485, p2 = 939, p3 = 966;
      var disp = '0' + p1 + ' ' + p2 + ' ' + p3;
      var tel  = '+61' + p1 + p2 + p3;
      document.querySelectorAll('.ph-cta').forEach(function(el){
        el.setAttribute('href', 'tel:' + tel);
        el.setAttribute('aria-label', 'Call ' + disp);
        var t = el.querySelector('.ph-text');
        if (t) t.textContent = ' ' + disp;
      });
    })();
  </script>
</body>
</html>
